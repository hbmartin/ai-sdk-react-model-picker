{
  "name": "ai-sdk-react-model-picker",
  "private": false,
  "version": "0.5.0",
  "description": "A flexible, theme-aware React component library for selecting and managing AI models. Built for seamless integration with Vercel's AI SDK v5, with special support for VSCode extensions and JetBrains IDEs.",
  "homepage": "https://github.com/hbmartin/ai-sdk-react-model-picker",
  "bugs": "https://github.com/hbmartin/ai-sdk-react-model-picker/issues",
  "keywords": [
    "ai",
    "ai-sdk",
    "react",
    "react-component",
    "react-library",
    "typescript",
    "controlled-components",
    "component-library",
    "vercel-ai-sdk",
    "ai-models",
    "model-selection",
    "vscode-extension",
    "ide-integration",
    "theme-aware",
    "plugin-architecture",
    "type-safe",
    "frontend",
    "ui-components"
  ],
  "type": "module",
  "author": {
    "name": "Harold Martin",
    "email": "harold.martin@gmail.com",
    "url": "https://www.linkedin.com/in/harold-martin-98526971/"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hbmartin/ai-sdk-react-model-picker.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind-preset": {
      "import": {
        "types": "./tailwind-preset.d.ts",
        "default": "./tailwind-preset.js"
      },
      "require": {
        "types": "./tailwind-preset.d.cts",
        "default": "./tailwind-preset.cjs"
      }
    }
  },
  "files": [
    "dist",
    "tailwind-preset.js",
    "tailwind-preset.cjs",
    "tailwind-preset.d.ts",
    "tailwind-preset.d.cts"
  ],
  "sideEffects": [
    "**/*.css",
    "**/styles/**"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -b && vite build && node -e \"require('fs').copyFileSync('dist/index.d.ts','dist/index.d.cts')\"",
    "lint": "eslint .",
    "lint:fix": "tsc --noEmit && eslint . --fix",
    "typecheck": "tsc --noEmit",
    "validate:packaging": "publint --strict && attw --pack . --exclude-entrypoints styles.css",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "preview": "vite preview",
    "prepublishOnly": "pnpm run build",
    "clean": "rm -rf dist node_modules/.tmp",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "pnpm run build && storybook build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "peerDependencies": {
    "@ai-sdk/amazon-bedrock": ">=5.0.0",
    "@ai-sdk/anthropic": ">=4.0.0",
    "@ai-sdk/azure": ">=4.0.0",
    "@ai-sdk/cohere": ">=4.0.0",
    "@ai-sdk/deepseek": ">=3.0.0",
    "@ai-sdk/google": ">=4.0.0",
    "@ai-sdk/mistral": ">=4.0.0",
    "@ai-sdk/openai": ">=4.0.0",
    "@ai-sdk/openai-compatible": ">=3.0.0",
    "@openrouter/ai-sdk-provider": ">=3.0.0",
    "ai-sdk-provider-claude-code": ">=4.0.0 <5.0.0",
    "ollama-ai-provider-v2": ">=4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.62.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/provider": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/openai-compatible": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/azure": {
      "optional": true
    },
    "@ai-sdk/mistral": {
      "optional": true
    },
    "@ai-sdk/cohere": {
      "optional": true
    },
    "@ai-sdk/amazon-bedrock": {
      "optional": true
    },
    "@openrouter/ai-sdk-provider": {
      "optional": true
    },
    "@ai-sdk/deepseek": {
      "optional": true
    },
    "ollama-ai-provider-v2": {
      "optional": true
    },
    "ai-sdk-provider-claude-code": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/amazon-bedrock": "^5.0.20",
    "@ai-sdk/anthropic": "^4.0.14",
    "@ai-sdk/azure": "^4.0.13",
    "@ai-sdk/cohere": "^4.0.9",
    "@ai-sdk/deepseek": "^3.0.9",
    "@ai-sdk/google": "^4.0.14",
    "@ai-sdk/mistral": "^4.0.10",
    "@ai-sdk/openai": "^4.0.13",
    "@ai-sdk/openai-compatible": "^3.0.9",
    "@ai-sdk/provider": "^4.0.3",
    "@arethetypeswrong/cli": "^0.18.5",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.9",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-onboarding": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.19.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.10",
    "ai": "^7.0.26",
    "ai-sdk-provider-claude-code": "^4.0.1",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-code-complete": "^1.5.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-storybook": "^10.5.0",
    "eslint-plugin-unicorn": "^71.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "ollama-ai-provider-v2": "^4.0.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "storybook": "^10.5.0",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  }
}
